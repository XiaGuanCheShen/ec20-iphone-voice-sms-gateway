# Copy to gateway.env and fill in your own values. Never commit gateway.env.

# Asterisk
SIP_EXTENSION=200
INSTALL_DIALPLAN=yes
# The gateway is assumed to use a dedicated custom dialplan file. This makes a backup
# and replaces /etc/asterisk/extensions_custom.conf.
REPLACE_EXTENSIONS_CUSTOM=no

# Optional EC20 serial PCM guard.
# Installs stable /dev/ec20-audio and /dev/ec20-at aliases plus an Asterisk
# startup wait hook. You still need to point /etc/asterisk/quectel.conf to
# those aliases after confirming your module interface numbers.
ENABLE_EC20_DEVICE_GUARD=no
EC20_VENDOR_ID=2c7c
EC20_MODEL_ID=0125
EC20_AUDIO_INTERFACE=01
EC20_AT_INTERFACE=02
EC20_DEVICE=quectel0
EC20_EXPECTED_TXGAIN=-5

# Bark: get the device key from the Bark app push URL.
BARK_SERVER=https://api.day.app
BARK_DEVICE_KEY=replace_with_bark_device_key
# Set the same AES-128-CBC Key and IV in the Bark app.
BARK_ENCRYPTION_KEY=replace_16_chars
BARK_ENCRYPTION_IV=replace_16_chars

# Feishu enterprise self-built app robot.
FEISHU_APP_ID=cli_replace_with_app_id
FEISHU_APP_SECRET=replace_with_app_secret
# Six digits used once when binding your Feishu account to the bot.
FEISHU_BIND_CODE=123456

# Optional DNSPod AAAA DDNS for direct IPv6 SIP access.
ENABLE_DNSPOD_DDNS=no
DNSPOD_LOGIN_TOKEN=replace_with_id_comma_token
DOMAIN=example.com
SUBDOMAIN=sip
NETWORK_INTERFACE=ens18

# Optional nftables firewall. Read docs/04-network-security.md before enabling.
ENABLE_FIREWALL=no
HOME_IPV4_LAN=192.168.1.0/24
